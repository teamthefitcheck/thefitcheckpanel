# ═══════════════════════════════════════════════════════════
#  Fit Check — Store Operations Panel
#  Powered by Arqontiq
#  Copy to .env for local dev. Set on Render for production.
# ═══════════════════════════════════════════════════════════

# ── Shopify ─────────────────────────────────────────────────
# Your store name — ONLY the part before .myshopify.com
SHOP_NAME=yourstore

# From: Shopify Partners → Apps → Your App → Client credentials
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Set automatically after running /install OAuth flow
# OR paste a private app token here directly
SHOPIFY_ACCESS_TOKEN=

# ── Branding ────────────────────────────────────────────────
BRAND_NAME=Fit Check

# ── Admin ───────────────────────────────────────────────────
ADMIN_PASSWORD=changeme123

# ── Server ──────────────────────────────────────────────────
PORT=3001
SERVER_URL=https://admin.fitcheck.com
ALLOWED_ORIGINS=*

# ── MongoDB ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/fitcheck?appName=Cluster

# ── WhatsApp (optional) ─────────────────────────────────────
WHATSAPP_NUMBER=919876543210
